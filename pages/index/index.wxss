/** index.wxss */
page {
  background-color: #f5f7fa;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
}

.page-header {
  margin-bottom: 24rpx;
  padding-left: 10rpx;
}

.page-title {
  display: flex;
  align-items: center;
  font-size: 38rpx;
  font-weight: 700;
  color: #1a1a1a;
  gap: 12rpx;
}

.page-icon {
  font-size: 40rpx;
}

.page-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8a8a8a;
}

.weather-card {
  margin-bottom: 24rpx;
  padding: 26rpx 26rpx 22rpx;
  background: #e9f7f0;
  border-radius: 24rpx;
  box-shadow: 0 10rpx 22rpx rgba(0, 0, 0, 0.06);
  position: relative;
  overflow: hidden;
}

.weather-card::before {
  content: '';
  position: absolute;
  right: -140rpx;
  top: -180rpx;
  width: 480rpx;
  height: 480rpx;
  background: radial-gradient(circle at 40% 40%, rgba(42, 245, 152, 0.55) 0%, rgba(0, 158, 253, 0) 65%);
  pointer-events: none;
}

.weather-card::after {
  content: '';
  position: absolute;
  left: -120rpx;
  bottom: -160rpx;
  width: 420rpx;
  height: 420rpx;
  background: radial-gradient(circle at 55% 45%, rgba(0, 158, 253, 0.18) 0%, rgba(0, 158, 253, 0) 70%);
  pointer-events: none;
}

.weather-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: relative;
  z-index: 1;
}

.weather-left {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.weather-icon {
  width: 84rpx;
  height: 84rpx;
  border-radius: 42rpx;
  background: rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 18rpx rgba(0, 0, 0, 0.06);
}

.weather-emoji {
  font-size: 44rpx;
  line-height: 1;
}

.weather-main {
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.weather-temp {
  font-size: 56rpx;
  font-weight: 800;
  color: #122b1d;
  line-height: 1;
}

.weather-unit {
  font-size: 30rpx;
  font-weight: 700;
  margin-left: 6rpx;
}

.weather-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: rgba(18, 43, 29, 0.7);
}

.weather-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

.risk-pill {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 1rpx;
}

.risk-high {
  background: #ff4d4f;
}

.risk-mid {
  background: #ff9f1a;
}

.risk-low {
  background: #1aad19;
}

.risk-unknown {
  background: rgba(18, 43, 29, 0.42);
}

.humidity {
  font-size: 24rpx;
  color: rgba(18, 43, 29, 0.75);
  font-weight: 600;
}

.weather-bottom {
  margin-top: 18rpx;
  position: relative;
  z-index: 1;
}

.weather-loc {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.loc-emoji {
  font-size: 28rpx;
  line-height: 1;
}

.loc-text {
  font-size: 26rpx;
  color: rgba(18, 43, 29, 0.88);
  font-weight: 700;
}

.weather-warn {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: rgba(18, 43, 29, 0.72);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.scan-card {
  padding: 40rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 2rpx dashed #d9d9d9;
  margin-bottom: 32rpx;
}

.scan-circle {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #2af598 0%, #009efd 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 20rpx rgba(0, 158, 253, 0.3);
}

/* CSS 绘制相机图标 */
.camera-icon {
  width: 60rpx;
  height: 40rpx;
  border: 4rpx solid #fff;
  border-radius: 6rpx;
  position: relative;
}
.camera-icon::before {
  content: '';
  position: absolute;
  top: -10rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 20rpx;
  height: 6rpx;
  background: #fff;
  border-radius: 4rpx 4rpx 0 0;
}
.camera-icon::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 20rpx;
  height: 20rpx;
  border: 4rpx solid #fff;
  border-radius: 50%;
}

.scan-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.scan-desc {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 40rpx;
  text-align: center;
}

.btn-start {
  background-color: #1aad19;
  color: #fff;
  border-radius: 40rpx;
  padding: 0 80rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 6rpx 16rpx rgba(26, 173, 25, 0.3);
  display: flex;
  align-items: center;
}

.icon-upload {
  margin-right: 10rpx;
  font-size: 36rpx;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.record-card {
  height: 176rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
}

.record-img {
  width: 104rpx;
  height: 104rpx;
  border-radius: 16rpx;
  background-color: #eee;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.record-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.record-top {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.record-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #222;
  margin-right: 16rpx;
}

.tag {
  font-size: 22rpx;
  padding: 6rpx 14rpx;
  border-radius: 22rpx;
  color: #fff;
}

.tag-danger { background-color: #e02020; }
.tag-warning { background-color: #ff9900; }
.tag-success { background-color: #1aad19; }

.record-date {
  font-size: 24rpx;
  color: #8a8a8a;
}

.record-arrow {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #f3f7f5;
  color: #7aa38f;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
