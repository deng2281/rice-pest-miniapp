.page {
  padding: 32rpx 24rpx 160rpx;
  box-sizing: border-box;
}

.header {
  padding: 12rpx 8rpx 28rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1f2d3d;
}

.subtitle {
  margin-top: 10rpx;
  font-size: 28rpx;
  color: #5f6c7b;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 18rpx 40rpx rgba(15, 23, 42, 0.08);
}

.toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.meta {
  font-size: 26rpx;
  color: #6b7280;
}

.meta-strong {
  color: #111827;
  font-weight: 700;
}

.tools {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.tool {
  font-size: 26rpx;
  color: #16a34a;
  font-weight: 700;
  padding: 10rpx 14rpx;
  border-radius: 14rpx;
  background: #f0fdf4;
  border: 1rpx solid rgba(22, 163, 74, 0.22);
}

.upload-frame {
  width: 100%;
  height: 420rpx;
  border-radius: 18rpx;
  background: #f8fafc;
  border: 2rpx dashed rgba(148, 163, 184, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
}

.placeholder-icon {
  font-size: 90rpx;
  line-height: 1;
  margin-bottom: 16rpx;
}

.placeholder-text {
  font-size: 28rpx;
  color: #111827;
  font-weight: 700;
}

.placeholder-sub {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.thumbs {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.thumb-item {
  position: relative;
  border-radius: 16rpx;
  overflow: hidden;
  background: #f3f4f6;
  height: 200rpx;
}

.thumb-img {
  width: 100%;
  height: 100%;
}

.thumb-mask {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.9);
  border: 2rpx solid #d1d5db;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #1aad19;
}

.thumb-mask.checked {
  background: #1aad19;
  border-color: #1aad19;
  color: #ffffff;
}

.thumb-status {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 8rpx 10rpx;
  font-size: 22rpx;
  color: #ffffff;
  background: linear-gradient(0deg, rgba(0, 0, 0, 0.65), transparent);
}

.thumb-del {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: rgba(17, 24, 39, 0.65);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  line-height: 1;
}

.thumb-add {
  height: 200rpx;
  border-radius: 16rpx;
  background: #f8fafc;
  border: 2rpx dashed rgba(148, 163, 184, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
}

.thumb-add-icon {
  font-size: 56rpx;
  line-height: 1;
  color: #111827;
  margin-bottom: 8rpx;
}

.thumb-add-text {
  font-size: 24rpx;
  color: #6b7280;
  font-weight: 700;
}

.cta {
  margin-top: 18rpx;
  width: 100%;
  height: 92rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #22c55e, #16a34a);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 32rpx rgba(22, 163, 74, 0.25);
}

.cta[disabled] {
  background: #e5e7eb;
  color: #9ca3af;
  box-shadow: none;
}

.hint {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #8a8a8a;
  text-align: center;
}
