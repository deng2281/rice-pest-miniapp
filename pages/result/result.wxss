/** result.wxss */
page {
  background-color: #f5f7fa;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
  padding-bottom: 40rpx;
}

.container {
  padding: 30rpx;
}

/* 结果卡片 */
.result-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 40rpx;
}

.card-header {
  margin-bottom: 24rpx;
}

.title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.main-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.severity-tag {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  color: #fff;
  font-weight: bold;
}

.tag-danger { background-color: #e02020; }
.tag-warning { background-color: #ff9900; }
.tag-success { background-color: #1aad19; }

.sub-title {
  font-size: 28rpx;
  color: #888;
  font-style: italic;
}

.result-image {
  width: 100%;
  height: 400rpx;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
  background-color: #eee;
}

.section-block {
  margin-bottom: 30rpx;
}

.block-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.block-content {
  font-size: 28rpx;
  color: #555;
  line-height: 1.6;
}

.confidence-block {
  background: #f9fbf9;
  padding: 24rpx;
  border-radius: 16rpx;
}

.confidence-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.confidence-label {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

.confidence-value {
  font-size: 32rpx;
  color: #1aad19;
  font-weight: bold;
}

.confidence-tip {
  font-size: 22rpx;
  color: #999;
  margin-top: 10rpx;
}

/* 详细诊断区域 */
.detail-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 40rpx;
}

.detail-title {
  font-size: 34rpx;
  font-weight: bold;
  margin-bottom: 24rpx;
  color: #333;
}

.tabs {
  display: flex;
  background: #f0f2f5;
  border-radius: 16rpx;
  padding: 6rpx;
  margin-bottom: 30rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666;
  border-radius: 12rpx;
}

.tab-item.active {
  background: #fff;
  color: #333;
  font-weight: bold;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.tab-content {
  min-height: 200rpx;
}

.content-box {
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.content-header {
  font-size: 30rpx;
  font-weight: bold;
  color: #1aad19;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.content-text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.6;
}

.harm-meter {
  display: flex;
  justify-content: space-between;
  margin-top: 20rpx;
  margin-bottom: 10rpx;
  font-size: 24rpx;
  color: #666;
}

/* 底部操作 */
.action-area {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.prevention-preview {
  margin-bottom: 30rpx;
}

.preview-title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.preview-desc {
  font-size: 26rpx;
  color: #888;
}

.btn-report {
  background-color: #1aad19;
  color: #fff;
  font-weight: bold;
  border-radius: 44rpx;
  margin-bottom: 24rpx;
  font-size: 32rpx;
}

.btn-rescan {
  background-color: #f2f2f2;
  color: #666;
  font-weight: 500;
  border-radius: 44rpx;
  font-size: 30rpx;
}
